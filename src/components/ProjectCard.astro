---
interface Props {
  project: {
    name: string;
    description: string;
    href: string;
    tags: string[];
  };
}

const { project } = Astro.props;
---

<article class="card project-card">
  <h3>{project.name}</h3>
  <p>{project.description}</p>
  <div class="tag-list" aria-label="技术标签">
    {project.tags.map((tag) => <span class="tag">{tag}</span>)}
  </div>
  <a class="button" href={project.href} target="_blank" rel="noreferrer">查看仓库</a>
</article>

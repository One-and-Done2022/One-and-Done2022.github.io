---
interface Props {
  kicker: string;
  title: string;
  copy?: string;
  href?: string;
  linkText?: string;
}

const { kicker, title, copy, href, linkText } = Astro.props;
---

<div class="section-header">
  <div>
    <p class="section-kicker">{kicker}</p>
    <h2 class="section-title">{title}</h2>
    {copy && <p class="section-copy">{copy}</p>}
  </div>
  {href && linkText && <a class="button" href={href}>{linkText}</a>}
</div>
